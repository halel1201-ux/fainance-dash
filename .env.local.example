# Supabase — copy this file to .env.local and fill in your project values.
# Project Settings → Data API / API Keys in the Supabase dashboard.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# SERVER ONLY — never exposed to the browser. Needed for admin user provisioning.
# Settings → API → service_role (secret). Add this to Vercel env vars too.
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-SECRET